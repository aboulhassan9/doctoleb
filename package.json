{
  "name": "clinic-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:patient": "vite --config apps/patient-web/vite.config.js",
    "dev:ops": "vite --config apps/clinic-ops/vite.config.js",
    "dev:control-plane": "vite --config apps/control-plane/vite.config.js",
    "dev:marketing": "vite --config apps/marketing/vite.config.js",
    "build": "vite build",
    "build:patient": "vite build --config apps/patient-web/vite.config.js",
    "build:ops": "vite build --config apps/clinic-ops/vite.config.js",
    "build:control-plane": "vite build --config apps/control-plane/vite.config.js",
    "build:marketing": "vite build --config apps/marketing/vite.config.js",
    "lint": "eslint .",
    "audit:backend-contract": "node scripts/backend-contract-audit.mjs",
    "audit:selects-drift": "node scripts/audit-selects-drift.mjs",
    "audit:rpc-signatures": "node scripts/audit-rpc-signatures.mjs",
    "audit:tenant-migration-flow": "node scripts/audit-tenant-migration-flow.mjs",
    "generate:tenant-migration-bundle": "node scripts/generate-tenant-migration-bundle.mjs",
    "check:tenant-migration-bundle": "node scripts/generate-tenant-migration-bundle.mjs --check",
    "test:backend-db-contract": "node scripts/backend-db-contract-tests.mjs",
    "test:unit": "node --test \"tests/unit/**/*.test.mjs\"",
    "test:unit:coverage": "node --test --experimental-test-coverage \"tests/unit/**/*.test.mjs\"",
    "test:pdfa": "node scripts/verify-pdfa-fixture.mjs",
    "test:e2e:local": "playwright test --config playwright.config.js",
    "test:e2e:install": "playwright install --with-deps chromium",
    "smoke:browser:deployed": "node scripts/browser-smoke.mjs",
    "smoke:auth:deployed": "node scripts/auth-login-smoke.mjs",
    "smoke:flows:deployed": "node scripts/deployed-flow-smoke.mjs",
    "smoke:csp:deployed": "node scripts/csp-smoke.mjs",
    "smoke:control-plane-admin-cors": "node scripts/control-plane-admin-cors-smoke.mjs",
    "smoke:tenant-resolver": "node scripts/tenant-resolver-smoke.mjs",
    "ci:classify": "node scripts/ci-change-classifier.mjs",
    "ci:watch": "node scripts/github-run-summary.mjs",
    "deploy:supabase-functions": "node scripts/deploy-supabase-functions.mjs",
    "seed:tenant:ops": "node scripts/seed-tenant-operational-data.mjs",
    "render:erd-views": "node scripts/render-erd-view-svgs.mjs",
    "generate:chartdb-erd": "node scripts/generate-chartdb-erd-json.mjs",
    "audit:bundle-secrets": "node scripts/bundle-secret-audit.mjs",
    "audit:high": "npm audit --audit-level=high",
    "verify": "npm run lint && npm run build && npm run check:tenant-migration-bundle && npm run audit:tenant-migration-flow && npm run test:unit && npm run test:pdfa && npm run audit:backend-contract && npm run audit:selects-drift && npm run audit:rpc-signatures && npm run test:backend-db-contract && npm run audit:high",
    "test": "npm run verify",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.104.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.76.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@pdf-lib/fontkit": "^1.1.1",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.4"
  }
}
