{
  "name": "clinic-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:patient": "vite --config apps/patient-web/vite.config.js",
    "dev:ops": "vite --config apps/clinic-ops/vite.config.js",
    "build": "vite build",
    "build:patient": "vite build --config apps/patient-web/vite.config.js",
    "build:ops": "vite build --config apps/clinic-ops/vite.config.js",
    "lint": "eslint .",
    "audit:backend-contract": "node scripts/backend-contract-audit.mjs",
    "test:backend-db-contract": "node scripts/backend-db-contract-tests.mjs",
    "audit:high": "npm audit --audit-level=high",
    "verify": "npm run lint && npm run build && npm run audit:backend-contract && npm run test:backend-db-contract && npm run audit:high",
    "test": "npm run verify",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.4"
  }
}
