VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_DEV_TENANT_SLUG=dev

# SaaS control-plane resolver. In local dev this may point to the live
# control-plane project while VITE_SUPABASE_* remains available as fallback.
VITE_TENANT_RESOLVER_URL=https://your-control-plane-ref.supabase.co/functions/v1/tenant-resolve
VITE_TENANT_RESOLVER_TIMEOUT_MS=6000

# Public deployment host routing. Use this while doctoleb.com is not purchased,
# or later when moving from Vercel-provided hosts to the real domain. Values are
# comma-separated hostnames or URLs; they are not secrets.
VITE_PUBLIC_PRIMARY_DOMAIN=doctoleb.com
VITE_MARKETING_HOSTS=
VITE_CONTROL_PLANE_HOSTS=
VITE_PATIENT_TENANT_HOSTS=
VITE_OPS_TENANT_HOSTS=

# SaaS super-admin console (`apps/control-plane`). This must point at the
# zero-PHI control-plane project, not a tenant clinical database.
VITE_CONTROL_PLANE_SUPABASE_URL=https://your-control-plane-ref.supabase.co
VITE_CONTROL_PLANE_SUPABASE_ANON_KEY=your-control-plane-public-anon-key

# Server-side only, set in Supabase Edge Function secrets for tenant sync.
# Example for tenant project ref gezmfmskhmjgnquoyosq:
# TENANT_SERVICE_ROLE_KEY_GEZMFMSKHMJGNQUOYOSQ=never-commit-real-service-key

# Cross-app links. Required once patient-web and clinic-ops are hosted on
# separate origins; localhost defaults are used in development when omitted.
VITE_PATIENT_WEB_URL=http://127.0.0.1:3001
VITE_CLINIC_OPS_URL=http://127.0.0.1:3002

# Backend contract tests:
# The runner falls back from BACKEND_TEST_SUPABASE_* to VITE_SUPABASE_*.
# Set BACKEND_TEST_ALLOW_LIVE=true only for read-only anon RPC exposure diagnostics.
BACKEND_TEST_SUPABASE_URL=https://your-branch-or-local-project.supabase.co
BACKEND_TEST_SUPABASE_ANON_KEY=your-branch-or-local-anon-key
BACKEND_TEST_ALLOW_LIVE=false

# Use a disposable Supabase branch/local Postgres URL for SQL audit + pgTAP.
# Do not commit real passwords.
BACKEND_TEST_DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
