VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Backend contract tests:
# The runner falls back from BACKEND_TEST_SUPABASE_* to VITE_SUPABASE_*.
# Set BACKEND_TEST_ALLOW_LIVE=true only for read-only anon RPC exposure diagnostics.
BACKEND_TEST_SUPABASE_URL=https://your-branch-or-local-project.supabase.co
BACKEND_TEST_SUPABASE_ANON_KEY=your-branch-or-local-anon-key
BACKEND_TEST_ALLOW_LIVE=false

# Use a disposable Supabase branch/local Postgres URL for SQL audit + pgTAP.
# Do not commit real passwords.
BACKEND_TEST_DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres
