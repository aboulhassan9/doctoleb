Project "DoctoLeb Staff Lifecycle Process ERD" {
  database_type: "PostgreSQL"
  Note: "Process ERD: invite, resend, reissue, disable, reactivate, and staff access context."
}

Table identity.auth_users {
  id uuid [pk]

  Note: 'Supabase Auth identity for login.'
}

Table identity.users {
  id uuid [pk]
  email varchar(255) [not null, unique]
  role varchar(50) [not null]
  first_name varchar(255)
  last_name varchar(255)
  phone varchar(20)
  avatar_url text
  initials varchar(5)
  is_active boolean
  created_at timestamptz
  updated_at timestamptz
  auth_user_id uuid

  Note: 'Application identity and role profile.'
}

Table identity.doctors {
  id uuid [pk]
  user_id uuid [not null, unique]
  department varchar(100)
  specialization varchar(100)
  license_number varchar(100) [unique]
  bio text
  availability json
  consultation_fee numeric(10,2)
  created_at timestamptz
  updated_at timestamptz
  provisioning_client_request_id uuid

  Note: 'Doctor/provider profile linked to a user.'
}

Table identity.staff_members {
  id uuid [pk]
  user_id uuid [unique]
  doctor_id uuid [not null]
  role text [not null]
  display_name text [not null]
  phone text
  email text
  invite_status text [not null]
  reports_to uuid
  hire_date date
  is_active boolean [not null]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  invite_client_request_id uuid
  disabled_at timestamptz
  disabled_by uuid
  disabled_previous_invite_status text
  invite_resent_at timestamptz
  invite_resent_by uuid
  invite_resend_count integer [not null]
  reactivated_at timestamptz
  reactivated_by uuid
  reactivation_count integer [not null]
  invite_reissued_at timestamptz
  invite_reissued_by uuid
  invite_reissue_count integer [not null]

  Note: 'Staff seat, role, and lifecycle state.'
}

Table identity.staff_invite_resend_events {
  id uuid [pk]
  staff_member_id uuid [not null]
  actor_user_id uuid [not null]
  client_request_id uuid [not null]
  email text [not null]
  status text [not null]
  error_code text
  requested_at timestamptz [not null]
  sent_at timestamptz
  failed_at timestamptz
  cancelled_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: 'Audit of repeated staff invite sends.'
}

Table identity.staff_invite_reissue_events {
  id uuid [pk]
  staff_member_id uuid [not null]
  actor_user_id uuid [not null]
  client_request_id uuid [not null]
  previous_auth_user_id uuid
  invited_auth_user_id uuid
  email text [not null]
  status text [not null]
  error_code text
  requested_at timestamptz [not null]
  sent_at timestamptz
  failed_at timestamptz
  cancelled_at timestamptz
  created_at timestamptz [not null]
  updated_at timestamptz [not null]

  Note: 'Audit of staff invite email changes.'
}

Table scheduling.secretary_slots {
  id uuid [pk]
  doctor_id uuid
  clinic_id uuid
  date date [not null]
  start_time time [not null]
  end_time time [not null]
  is_active boolean [not null]
  created_by uuid [not null]
  recurrence_group_id uuid
  created_at timestamptz
  schedule_template_id uuid

  Note: 'Bookable slot created from schedule or staff.'
}

Table audit.audit_log {
  id uuid [pk]
  table_name text [not null]
  record_id uuid [not null]
  action text [not null]
  actor_user_id uuid
  before_data jsonb
  after_data jsonb
  created_at timestamptz [not null]

  Note: 'Audit trail for staff and tenant admin changes.'
}

TableGroup "identity" [color: #2563EB] {
  identity.auth_users
  identity.users
  identity.doctors
  identity.staff_members
  identity.staff_invite_resend_events
  identity.staff_invite_reissue_events

  Note: 'Login users, doctors, staff, and roles.'
}
TableGroup "scheduling" [color: #D97706] {
  scheduling.secretary_slots

  Note: 'Clinics, availability, slots, and bookings.'
}
TableGroup "audit" [color: #64748B] {
  audit.audit_log

  Note: 'Audit and lifecycle events.'
}

Note relationship_story {
  'Relation: auth user becomes staff member; invite events and audit prove lifecycle changes.'
}

Note relationship_legend {
  'Ref format: left foreign key > right owner. Line color follows the left table area.'
}

Ref: identity.users.auth_user_id > identity.auth_users.id [color: #2563EB]
Ref: identity.doctors.user_id > identity.users.id [color: #2563EB]
Ref: identity.staff_members.user_id > identity.users.id [color: #2563EB]
Ref: identity.staff_members.doctor_id > identity.doctors.id [color: #2563EB]
Ref: identity.staff_members.reports_to > identity.staff_members.id [color: #2563EB]
Ref: identity.staff_members.disabled_by > identity.users.id [color: #2563EB]
Ref: identity.staff_members.invite_resent_by > identity.users.id [color: #2563EB]
Ref: identity.staff_members.invite_reissued_by > identity.users.id [color: #2563EB]
Ref: identity.staff_members.reactivated_by > identity.users.id [color: #2563EB]
Ref: identity.staff_invite_resend_events.staff_member_id > identity.staff_members.id [color: #2563EB]
Ref: identity.staff_invite_resend_events.actor_user_id > identity.users.id [color: #2563EB]
Ref: identity.staff_invite_reissue_events.staff_member_id > identity.staff_members.id [color: #2563EB]
Ref: identity.staff_invite_reissue_events.actor_user_id > identity.users.id [color: #2563EB]
Ref: scheduling.secretary_slots.created_by > identity.users.id [color: #D97706]
Ref: scheduling.secretary_slots.doctor_id > identity.doctors.id [color: #D97706]
Ref: audit.audit_log.actor_user_id > identity.users.id [color: #64748B]
