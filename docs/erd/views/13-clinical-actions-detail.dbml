Ref: clinical.lab_orders.doctor_id > identity.doctors.id [color: #E11D48]
Ref: clinical.lab_orders.ordered_by > identity.users.id [color: #E11D48]
Ref: clinical.lab_orders.result_document_id > clinical.clinical_documents.id [color: #E11D48]
Ref: clinical.imaging_orders.encounter_id > clinical.encounters.id [color: #E11D48]
