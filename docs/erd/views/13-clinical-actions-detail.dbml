Ref: clinical.clinical_documents.voided_by > identity.users.id [color: #E11D48]
Ref: clinical.document_attachments.document_id > clinical.clinical_documents.id [color: #E11D48]
Ref: clinical.document_attachments.patient_id > patient_record.patients.id [color: #E11D48]
Ref: clinical.document_attachments.uploaded_by > identity.users.id [color: #E11D48]
Ref: clinical.precheck_forms.patient_id > patient_record.patients.id [color: #E11D48]
Ref: clinical.precheck_forms.predoctor_id > identity.predoctors.id [color: #E11D48]
Ref: identity.predoctors.user_id > identity.users.id [color: #2563EB]
Ref: identity.predoctors.supervisor_id > identity.doctors.id [color: #2563EB]
