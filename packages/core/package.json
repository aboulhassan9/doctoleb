{
  "name": "@doctoleb/core",
  "version": "0.0.1",
  "private": true,
  "description": "Shared business logic — services, schemas, hooks, and utilities for DoctoLeb apps",
  "type": "module",
  "exports": {
    "./services/*": "./services/*.js",
    "./schemas": "./schemas/index.js",
    "./lib/*": "./lib/*.js",
    "./hooks": "./hooks/index.js",
